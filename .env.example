PORT=5000

# Used automatically inside Docker Compose (mongodb service hostname).
# For local development without Docker, point this at your MongoDB instance.
DB_URL=mongodb://localhost:27017/myapp_db

SECRET=change_me_to_a_long_random_string

cloud_name=your_cloudinary_cloud_name
api_key=your_cloudinary_api_key
api_secret=your_cloudinary_api_secret

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Email (OTP login)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Your Shop <your-email@gmail.com>"
